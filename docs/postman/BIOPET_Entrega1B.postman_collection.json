{
  "info": {
    "name": "BIOPET - Entrega 1B",
    "description": "Coleccion lista para la Entrega 1B. Ejecuta las peticiones EN ORDEN (de arriba hacia abajo). Los tokens y los IDs se guardan automaticamente, no necesitas copiar nada. Asegurate de tener el backend corriendo (docker compose up) antes de empezar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "duenioId",
      "value": ""
    },
    {
      "key": "mascotaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Registro (dueno)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/registro",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "registro"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"email\": \"juan@uteq.edu.ec\",\n  \"password\": \"Password123\",\n  \"rol\": \"ROLE_DUENO\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('duenioId', pm.response.json().id);",
              "  console.log('duenioId guardado: ' + pm.response.json().id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login (dueno)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"juan@uteq.edu.ec\",\n  \"password\": \"Password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('accessToken', pm.response.json().accessToken);",
              "  console.log('accessToken (dueno) guardado');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Login (admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@biopet.ec\",\n  \"password\": \"Admin123*\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('adminToken', pm.response.json().accessToken);",
              "  console.log('adminToken guardado');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Crear mascota (admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/mascotas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mascotas"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"duenioId\": {{duenioId}},\n  \"nombre\": \"Firulais\",\n  \"especie\": \"Canino\",\n  \"raza\": \"Labrador\",\n  \"fechaNacimiento\": \"2021-05-10\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('mascotaId', pm.response.json().id);",
              "  console.log('mascotaId guardado: ' + pm.response.json().id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Listar mascotas (paginado)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/mascotas?page=0&size=10&sort=id,asc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mascotas"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            },
            {
              "key": "sort",
              "value": "id,asc"
            }
          ]
        }
      }
    },
    {
      "name": "6. Buscar mascota por ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mascotas",
            "{{mascotaId}}"
          ]
        }
      }
    },
    {
      "name": "7. Actualizar mascota",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mascotas",
            "{{mascotaId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"duenioId\": {{duenioId}},\n  \"nombre\": \"Firulais Editado\",\n  \"especie\": \"Canino\",\n  \"raza\": \"Golden Retriever\",\n  \"fechaNacimiento\": \"2021-05-10\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "8. Eliminar mascota (soft delete)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mascotas",
            "{{mascotaId}}"
          ]
        }
      }
    },
    {
      "name": "9. Perfil del usuario (me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios",
            "me"
          ]
        }
      }
    },
    {
      "name": "10. Acceso SIN token (debe dar 401)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios",
            "me"
          ]
        }
      }
    },
    {
      "name": "11. Logout (revoca el token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        }
      }
    }
  ]
}
